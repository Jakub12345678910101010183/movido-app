# ============================================
# MOVIDO - Environment Variables
# Copy this file as .env and fill in your values
# ============================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# TomTom Maps API
VITE_TOMTOM_API_KEY=your_tomtom_api_key_here

# Server Configuration (not needed for Vite frontend)
# PORT=3000
# NODE_ENV=development

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Price IDs (set these in Vercel dashboard + Supabase secrets)
VITE_STRIPE_PRICE_STARTER_MONTHLY=price_xxx
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_xxx
VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxx
VITE_STRIPE_PRICE_PRO_ANNUAL=price_xxx

# For Supabase Edge Functions (set via: supabase secrets set)
# STRIPE_PRICE_STARTER_MONTHLY=price_xxx
# STRIPE_PRICE_STARTER_ANNUAL=price_xxx
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_ANNUAL=price_xxx
